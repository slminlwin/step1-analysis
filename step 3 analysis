    for mat_file_idx=flist{exp}
        cd(folder_data);
        load(mat_file_names{mat_file_idx});

        if mat_file_idx == 1 % kirxCS
            q=1;
        elseif mat_file_idx == 14 %LT39xTNT
            q=3;
        elseif mat_file_idx<=13 && rem(mat_file_idx, 2) == 0  % SplitGal4xCS
            q=2;
        elseif mat_file_idx<=13 && rem(mat_file_idx, 2) == 1  % SplitGal4xKir
            q=4;
        elseif mat_file_idx>14 && rem(mat_file_idx, 2) == 1  % SplitGal4xCS
            q=2;
        elseif mat_file_idx>14 && rem(mat_file_idx, 2) == 0  % SplitGal4xKir
            q=4;
        end

        %%%%%%%%%%%%%%%%%% calculate peak mean wba %%%%%%%%%%%%%%%%%%%%
        stimEnd=ones(1,size(wba_flyavg,1))*1.7;
        stimEnd(13:19)=[1.72 1.76 1.78 1.78 1.64 2.06 2.64];
        
        for p=1:1:size(wba_flyavg,1)
            if isnan(sum(t{p})) && sum(ismember([3,20,23],p))==1 && ~isnan(sum(t{26}))
                t{p}=t{26};
            % elseif isnan(sum(t{26})) && sum(ismember(26,p))==1 && ~isnan(sum(t{23}))
            %     t{26}=t{23};
            elseif isnan(sum(t{p})) && sum(ismember([3,20,23],p))==0 && ~isnan(sum(t{2}))
                t{p}=t{2};
            elseif isnan(sum(t{p})) && sum(ismember([3,20,23],p))==0 && ~isnan(sum(t{4}))
                t{p}=t{4};
            elseif isnan(sum(t{2})) && sum(ismember(2,p))==1 && ~isnan(sum(t{1}))
                t{p}=t{1};
            end
            baseline_idx=find(t{p}>1.3 & t{p}<1.5);
            response_idx{p}=find(t{p}>stimEnd(p)-.05 & t{p}<=stimEnd(p)+.15);
            response_idx2{p}=find(t{p}>stimEnd(p) & t{p}<=stimEnd(p)+.2);
        end
        for p=1:1:size(wba_flyavg,1)
            wba_popavg{p}=mean(cell2mat(wba_flyavg(p,:)'),1,'omitnan');
        end

        %%%%%%%%%%% control flies %%%%%%%%%%%%%
        for p=1:1:size(wba_flyavg,1)
            if sum(ismember([7:19,21:22,24:25],p))==1
                wba_popavg{p}(1,:)= -wba_popavg{p}(1,:);
            end
            wba_popavg{p}=wba_popavg{p}-mean(wba_popavg{p}(1,baseline_idx),'omitnan');
            for n=1:size(wba_flyavg,2)
                based_WBA{p,n}=wba_flyavg{p,n}-mean(wba_flyavg{p,n}(1,baseline_idx),'omitnan');
                mean_peak{q}(p,n)= mean(based_WBA{p,n}(1,response_idx{p}),'omitnan');
                mean_peak2{q}(p,n)= mean(based_WBA{p,n}(1,response_idx2{p}),'omitnan');
                if sum(ismember([7:19,21:22,24:25],p))==1
                    mean_peak{q}(p,n)= -mean_peak{q}(p,n);
                    mean_peak2{q}(p,n)= -mean_peak2{q}(p,n);
                end
                
            end
        end

        num(q)=size(wba_flyavg,2);

        sem{q}=(std(mean_peak{q},[],2,'omitnan')*1.96)/sqrt(num(q));
        sem2{q}=(std(mean_peak2{q},[],2,'omitnan')*1.96)/sqrt(num(q));

        %%
        %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
        %%%%%%%%%%%%%%%%%%%%%%%%%% plot traces %%%%%%%%%%%%%%%%%%%%%%%%
        %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
        f1=figure(1); set(gcf,'Color','w');set(gca,'Box','off');
        cm='kbgr'; cm_tr=[0 0 0 0.1; 0 0 1 0.5; 1 0 0 0.1];
        loom_dur=[0.22 0.26 0.28 0.28 0.14 0.56 1.14];

        for p=1:1:size(wba_flyavg,1)
            subplot(6,5,p);
            if q==1  % splitGal4xKir
                %%%%%%%%%for 10 sec stimuli %%%%%%%%%
                if p==3 || p==20 || p==23 || p==26
                    rectangle('Position',[0 -40 10 120],'FaceColor',[0.8 0.8 0.8],'FaceAlpha',0.5,'LineStyle','none');hold all;
                    xlim([-1,12]); ylim([-10 25]);
                elseif sum(ismember([13:17],p))==1
                    rectangle('Position',[1.5 -40 loom_dur(p-12) 120],'FaceColor',[0.8 0.8 0.8],'FaceAlpha',0.5,'LineStyle','none');hold all;
                    xlim([1.4, 2]); ylim([-10 50]);
                elseif sum(ismember([18:19],p))==1
                    rectangle('Position',[1.5 -40 loom_dur(p-12) 120],'FaceColor',[0.8 0.8 0.8],'FaceAlpha',0.5,'LineStyle','none');hold all;
                    xlim([1.4, 3.3]); ylim([-10 50]);
                else
                    rectangle('Position',[1.5 -40 0.2 120],'FaceColor',[0.8 0.8 0.8],'FaceAlpha',0.5,'LineStyle','none');hold all;
                    xlim([1.4, 2]); ylim([-10 40]);55
                end
            end
            for n=1:size(wba_flyavg,2)
                wba_flyavg2{p}(n,:)=wba_flyavg{p,n};
            end
            for i=1:size(wba_popavg{p},2)
