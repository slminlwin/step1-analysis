                lowerSEM{p}(1,i)=wba_popavg{p}(1,i)-std(wba_flyavg2{p}(:,i),[],1,'omitnan')/sqrt(num(q))*1.96;
            end


            fill([t{p} fliplr(t{1,p})],[upperSEM{p} fliplr(lowerSEM{p})],...
